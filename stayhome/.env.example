# --- Database (Neon PostgreSQL) ---
# Pooled connection — used by the running app via @prisma/adapter-pg
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=verify-full&channel_binding=require"
# Direct connection — used by `prisma migrate` / `prisma db push`
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=verify-full&channel_binding=require"

# --- NextAuth v5 ---
# `openssl rand -base64 32`
AUTH_SECRET=""
AUTH_TRUST_HOST=true
AUTH_URL="http://localhost:3000"

# Google OAuth client (Google Cloud Console > Credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Resort credential encryption (AES-256-GCM) ---
# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
RESORT_CRED_SECRET=""

# --- Inngest ---
# Required only in production / Inngest cloud. Local dev uses inngest-cli.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- Playwright on Vercel ---
# Tarball URL matching the installed @sparticuz/chromium-min version
# Upload to R2 / S3 and point here. Example:
#   https://github.com/Sparticuz/chromium/releases/download/v131.0.1/chromium-v131.0.1-pack.tar
CHROMIUM_PACK_URL=""

# --- Local debugging ---
# Set to "false" to watch the crawler in a real browser window during dev.
# Ignored in production (CHROMIUM_PACK_URL is set → forced headless).
CRAWLER_HEADLESS="true"

# --- Cron protection ---
# Random secret; required header `Authorization: Bearer ${CRON_SECRET}` on /api/cron/refresh
CRON_SECRET=""

# --- Optional: Slack webhook for crawl failure alerts (post-MVP) ---
SLACK_WEBHOOK_URL=""
